# --- Database ---
DATABASE_URL="postgresql://lms_user:lms12345@localhost:5432/lms_db?schema=public"

# --- App ---
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# --- JWT ---
JWT_ACCESS_SECRET="change_me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_me"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Video token ---
VIDEO_TOKEN_SECRET="change_me"
VIDEO_TOKEN_TTL_SECONDS=600

# --- Device limit ---
MAX_DEVICES_PER_USER=2

# --- Enrollment ---
DEFAULT_ENROLLMENT_DURATION_DAYS=120

# --- Object storage (S3-compatible / MinIO) — IXTIYORIY (faqat video/PDF yuklash uchun) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="lms-media"
S3_ACCESS_KEY_ID="lms_minio"
S3_SECRET_ACCESS_KEY="lms_minio_password"
S3_FORCE_PATH_STYLE=true

# --- Email (SMTP) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASSWORD="change_me"
SMTP_FROM="O'quv Platformasi <no-reply@example.com>"

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_OWNER_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET="change_me"
